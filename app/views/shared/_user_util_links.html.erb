<ul class="navbar-nav">
  <%= render_nav_actions do |config, action|%>
    <li class="nav-item"><%= action %></li>
  <% end %>

  <% if has_user_authentication_provider? %>
    <% if current_user %>
      <li class="nav-item">
        <%= link_to t('blacklight.header_links.logout'), logout_path, class: 'nav-link' %>
      </li>
      <li class="nav-item">
        <%= link_to current_user.to_s, bookmarks_path, class: 'nav-link' %>
      </li>
    <% end %>
  <% end %>
</ul>
